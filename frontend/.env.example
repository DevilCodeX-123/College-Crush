# Environment variables for College Crush Frontend

# The URL for your backend API (e.g., deployed on Render/Railway)
# Example: https://college-crush-backend.onrender.com/api
VITE_API_URL=http://localhost:5000/api

# The URL for your backend Socket server
# Example: https://college-crush-backend.onrender.com
VITE_SOCKET_URL=http://localhost:5000
